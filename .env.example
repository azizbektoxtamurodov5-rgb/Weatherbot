# Telegram Bot API Token (kerak va muhim)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Weather API (OpenWeatherMap) - ixtiyoriy, default mavjud
WEATHER_API_KEY=cfb18895da0d8bf04a8307cc8550fe0d

# AI API Keys - kamida birini o'rnatish kerak (Gemini tavsiya qilinadi)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# AI Models - ixtiyoriy (defaults mavjud)
GEMINI_MODEL=gemini-2.5-flash
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-4o

# Video generation API configuration
VIDEO_API_URL=https://example.com/api/video
VIDEO_API_KEY=your_video_api_key_here
# Agar API kaliti Authorization header bo'lsa, uni quyidagicha sozlang:
# VIDEO_API_KEY_HEADER=Authorization
# Agar API kaliti oddiy x-api-key bo'lsa:
# VIDEO_API_KEY_HEADER=x-api-key
# Agar qo'shimcha so'rov maydonlari kerak bo'lsa, JSON sifatida kiriting:
# VIDEO_API_EXTRA={"model":"your-model","quality":"high"}
